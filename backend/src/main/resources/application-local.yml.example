# =============================================================================
# 使用方式：复制本文件为同目录下的 application-local.yml，填写下方占位符。
# application-local.yml 已在 .gitignore 中，不要提交到 Git。
#
# 与「另一个项目」共用同一对 AccessKey 时：只需把 bucket 改成新建的桶名即可。
# 本仓库默认桶名为 medi-multi（华东2-上海），与 endpoint 区域必须一致。
# =============================================================================

alioss:
  enabled: true
  # 与控制台 Bucket 所属地域一致：上海 = oss-cn-shanghai.aliyuncs.com
  endpoint: oss-cn-shanghai.aliyuncs.com
  access-key-id: <你的 AccessKeyId>
  access-key-secret: <你的 AccessKeySecret>
  # 控制台新建的 Bucket 名称，例如 medi-multi
  bucket-name: medi-multi
  # 对象键前缀，上传后完整路径类似：uploads/u1/medical/xxx-文件名
  object-prefix: uploads/

# 可选：用环境变量覆盖（适合服务器部署，不必写进文件）
# export ALIYUN_OSS_ENABLED=true
# export ALIYUN_OSS_BUCKET=medi-multi
# export ALIYUN_OSS_ACCESS_KEY_ID=...
# export ALIYUN_OSS_ACCESS_KEY_SECRET=...
